{
    admin off
}

:{$PORT} {
    root * /app
    php_fastcgi 127.0.0.1:9000
    file_server

    # Serve index.html or index.php as directory index
    try_files {path} {path}/ /index.html

    # Allow all static assets directly
    @static {
        path *.css *.js *.png *.jpg *.jpeg *.gif *.ico *.svg *.woff *.woff2 *.ttf
    }
    handle @static {
        file_server
    }
}
